# Trapotato frontend — environment template. Copy to `.env.local` (never commit secrets).

# Public base URL of the Trapotato verify-server (license + waitlist backend).
# The early-access form posts to `${NEXT_PUBLIC_VERIFY_API_URL}/api/early-access`.
# Example:
#   NEXT_PUBLIC_VERIFY_API_URL=https://verify.fortiqo.xyz
NEXT_PUBLIC_VERIFY_API_URL=
